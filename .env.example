# Copie ce fichier en `.env` puis remplis les valeurs.
#   cp .env.example .env
#
# Où trouver ces valeurs : tableau de bord Supabase de ton projet
#   → Project Settings → API
#   - "Project URL"      => VITE_SUPABASE_URL
#   - "anon public" key  => VITE_SUPABASE_ANON_KEY
#
# La clé "anon" est PUBLIQUE par conception (elle finit dans le bundle navigateur).
# La sécurité repose sur les Row Level Security policies de Supabase — voir docs/security.md.
# Ne mets JAMAIS la clé "service_role" ici.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
